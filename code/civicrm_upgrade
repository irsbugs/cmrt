def get_dir_file_owner(file_path):
    """
    Get the owner and group names based on a file or directory
    Return: user_name, group_name
    """
    # Get file status
    file_stat = os.stat(file_path)

    # Retrieve user and group IDs
    user_id = file_stat.st_uid
    group_id = file_stat.st_gid

    # Map IDs to names
    user_name = pwd.getpwuid(user_id).pw_name
    group_name = grp.getgrgid(group_id).gr_name

    #print(file_path)
    #print("Owner:", user_name)
    #print("Group:", group_name)
    return user_name, group_name


def compare(civi_file_hash, file_hash):
    """
    Check the SHA256 sums match
    """
    if civi_file_hash != file_hash:
        exit_program("SHA256 do not match")
    else:
        print("SHA256 match.")
    return 1


def get_calculate_file_hash(file_path):
    """
    Calculate the SHA256 of the downloaded CiviCRM tar.gz.file in civicrm-upgrade
    """
    hash_obj = hashlib.sha256()
    with open(file_path, "rb") as file:
        while True:
            data = file.read(8192)
            if not data:
                break
            hash_obj.update(data)
    return hash_obj.hexdigest()


def get_sha256_from_civi_file(file_path, file_name):
    """
    Extract sha256 for civicrm standalone from SHA256SUMS file.
    # E.g. file_name = "civicrm-6.14.1-standalone.tar.gz"
    """
    with open(file_path, "r") as fin:
        for line in fin.readlines():
            if file_name not in line:
                continue
            else:
                #print(line)
                position = line.index(" ")
                #print(position)
                sha256 = line[:position]
                #print(sha256)
                #print(len(sha256))
                break
    return sha256


def backup_dir_cleanup():
    """
    Select Directories and Files to delete in backup directory.
    Note: The select function reverses the list
    Perform via the HOME directory
    Also call at very end of running program. for final cleanup
    """
    os.chdir(HOME)
    while True:
        command_list = ["Do not delete any - Continue", "Delete all-but most recent", "Delete all"]
        dir_list = []
        file_list = []
        path = BACKUP_DIR
        for item in os.listdir(path):
            item = item.strip()
            full_path = os.path.join(path, item)
            if os.path.isdir(full_path):
                dir_list.append(item)
            else:
                file_list.append(item)
        dir_list_sorted = sorted(dir_list) # Need to sort so date has newest at top
        file_list_sorted = sorted(file_list)
        #for item in file_list_sorted:
            #print("\t{}".format(item))

        # If lists are empty then skip this step.
        if len(dir_list_sorted) == 0 and len(file_list_sorted) == 0:
            print("\nBackup folder, {}, is empty".format(BACKUP_DIR))
            break

        prompt = "\nSelect Directories and Files to delete in: {}".format(BACKUP_DIR)
        select_list = command_list + dir_list_sorted + file_list_sorted
        default = 0
        result_int, result_str = selector(prompt, select_list, default)
        #print(result_int, result_str)

        if result_int == 0:
            print("\nFinished cleanup of backup directory")
            break

        if result_int == 1:
            print("\nDelete all-but most recent")
            # Get pop the dir_list_sorted and file_list_sorted to get to keep
            # Pop the most recent file/dir from the lists
            if len(dir_list_sorted) > 0:
                dir_list_sorted.pop()
            if len(file_list_sorted) > 0:
                file_list_sorted.pop()

            # Delete the remaining files. and trees
            #print(dir_list_sorted)  # Missing the most recent dir
            #print(file_list_sorted)  # Missing most recent file
            for item in file_list_sorted:
                os.remove(BACKUP_DIR + os.sep + item)
            for item in dir_list_sorted:
                shutil.rmtree(BACKUP_DIR + os.sep + item)
            continue

        if result_int == 2:
            print("\nDelete all")
            for item in file_list_sorted:
                os.remove(BACKUP_DIR + os.sep + item)
            for item in dir_list_sorted:
                shutil.rmtree(BACKUP_DIR + os.sep + item)
            break
            #continue

        if result_int > 2:
            print("\nDeleting {}. {}".format(result_int, result_str))
            # Deleting 7. civicrm_6.2.0_backup_files_2026-05-30_21:44:29
            # Deleting 15. civicrm_6.2.0_backup_dbase_2026-05-30_21:43:58.sql
            # Is it .sql file or a tree of files
            if result_str.endswith(".sql"):
                os.remove(BACKUP_DIR + os.sep + result_str)
            else:
                shutil.rmtree(BACKUP_DIR + os.sep + result_str)
            continue


def backup_civicrm():
    """
    Backup of CiviCRM Standalone. Backup production directory and then database

    From CIVICRM_DIR to dated sub-dir of BACKUP_DIR
    The backups are placed in their own dated sub-directory.
    The subdirectory will contain tree of civicrm-standalone and civicrm sql database

    Note: backup_dir_cleanup() has been performed to purge selected old backups.

    Note: CIVICRM_VERSION has already been captured from version.xml file
    In CiviCRM standalone the version is in: /civicrm-standalone/core/xml/version.xml

    Note: shutil.copytree() creates the top-level directory name

    Use HOME dir not BACKUP_DIR
    """
    #  Stay at HOME
    os.chdir(HOME)

    print("\nPerforming backup operations to: {}".format(BACKUP_DIR))

    # Create a new backup sub-dir based on the date. civicrm-backup-2026-05-29
    DATE_TIME = datetime.today().strftime('%Y-%m-%d_%H:%M:%S')
    #print(DATE_TIME) # 2026-05-29_10:09:27
    SUB_BACKUP_DIR_NAME = "civicrm_{}_backup_files_{}".format(CIVICRM_VERSION, DATE_TIME)
    print("CiviCRM backup sub-directory: /{}".format(SUB_BACKUP_DIR_NAME))

    #===== Files Tree Backup =====
    print("Backing up CiviCRM files...")
    # Get total files and directories
    dir_and_file_count(CIVICRM_DIR)

    #Perform tree copy of CiviCRM
    shutil.copytree(CIVICRM_DIR, BACKUP_DIR + os.sep + SUB_BACKUP_DIR_NAME)

    #print('Backed up files in directory: {}'.format(BACKUP_DIR + os.sep + SUB_BACKUP_DIR_NAME))
    print('Backed up files in directory: /{}'.format(SUB_BACKUP_DIR_NAME))
    dir_and_file_count(BACKUP_DIR + os.sep + SUB_BACKUP_DIR_NAME)

    #===== DB Backup =====
    print("\nPerforming Backup of Database to: {}".format(BACKUP_DIR))
    # Use mysqldump to create a backup of CiviCRM database
    DB_BACKUP_FILE = "civicrm_{}_backup_dbase_{}.sql".format(CIVICRM_VERSION, DATE_TIME)
    output_file = BACKUP_DIR + os.sep + DB_BACKUP_FILE
    command_str = 'mysqldump --defaults-file={} {}'.format(CIVICRM_CNF, DATABASE_NAME)
    command_list = command_str.split()

    try:
        with open(output_file, 'wb') as fout:
            process = subprocess.Popen(
                command_list,
                stdout=fout,
                stderr=subprocess.PIPE,
            )

            # Wait for the command to finish and get stderr
            _, stderr_output = process.communicate()

            if process.returncode == 0:
                print "Backup successfully created: {}".format(DB_BACKUP_FILE)
            else:
                print "mysqldump failed with exit code: {}".format(process.returncode)
                print "Error: {}".format(stderr_output)

    except OSError as e:
        print "Failed to execute mysqldump. Is it installed and in your PATH?"
        print "Details: {}".format(e)
    except Exception as e:
        print "An error occurred: {}".format(e)

    print("Database backup completed")


def mysql_queries_info():
    """
    Perform some database queries, using subprocess as no mysql.connector,
    Notes:
      --defaults-file={} must be the first option in the command
      --silent removes the headings
      subprocess.check_output() will pass output string to variable and has no heading
      default value for the shell parameter in subprocess.check_output is False.

    """
    os.chdir(HOME)
    print("\nPerforming MySQL queries of Database. Access is using: {}".format(CIVICRM_CNF))

    # 1. Show Databases
    command_str = 'mysql --defaults-file={} --silent'.format(CIVICRM_CNF)
    # Convert to a list
    command_list = command_str.split()
    # Append --execute as there is a space (delimiter) in the 'SHOW DATABASE'.
    command_list.append('--execute=SHOW DATABASES;')
    output_str = subprocess.check_output(command_list).strip()
    output_list = output_str.split("\n")
    print("MariaDB databases available.")
    for index, item in enumerate(output_list):
        print("\t{}. {}".format(index+1, item))

    # 2. Get contacts in civicrm_uf_match table.
    command_str = 'mysql --defaults-file={} --silent'.format(CIVICRM_CNF)
    command_list = command_str.split()
    command_list.append('--execute=SELECT id, uf_id, uf_name, domain_id FROM civicrm_uf_match')
    output_str = subprocess.check_output(command_list).strip()
    output_list = output_str.split("\n")
    print("Civicrm uf_match column.")
    for index, item in enumerate(output_list):
        print("\t{}. {}".format(index+1, item))

    # 3. Get the Contacts with Admin surname in CiviCRM Standalone database from civicrm_contact table.
    command_str = 'mysql --defaults-file={} --silent'.format(CIVICRM_CNF)
    command_list = command_str.split()
    command_list.append('--execute=SELECT ID, first_name, last_name FROM civicrm_contact WHERE last_name = "Admin";')
    output_str = subprocess.check_output(command_list).strip()
    output_list = output_str.split("\n")
    print("Civicrm Contacts with Admin as last name.")
    for index, item in enumerate(output_list):
        print("\t{}. {}".format(index+1, item))

