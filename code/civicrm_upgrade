    Check if BACKUP_DIR, ~/civicrm-backup, exists. If not, then create it.
    Used to hold date-based backup directories.
    """
    os.chdir(HOME)
    if not os.path.isdir(BACKUP_DIR):
        os.mkdir(BACKUP_DIR)

    print("CiviCRM Backup directory exists: {}".format(BACKUP_DIR))


def dir_and_file_count(path):
    """
    In a directory tree count totals of files and directories
    Uses os.
    """

    # Initialize counters
    file_count = 0
    dir_count = 0

    # Traverse the directory tree
    for root, dirs, files in os.walk(path):
        dir_count += len(dirs)  # Count directories
        file_count += len(files)  # Count files

    # Print the results
    print('Total directories: {}. Total files: {}'.format(dir_count, file_count))


def get_civicrm_release_list():
    """
    Get a list of the current release and up to 5 new releases since.

    Note: Can re-install current version, but doesn't support going back to previous versions.
    When using the Browser to complete installation: System Status Error
    ===
    Database in Unexpected Version
    Your database is marked with an unexpected version number: 6.14.2.
    The v6.14.1 codebase may not be compatible with your database state.
    You will need to determine the correcxt version corresponding to your current database state.
    You may want to revert to the codebase you were using until you resolve this problem.
    OR If this is a manual install from git, you might want to fix civicrm-version.php file
    ===

    Return: civicrm_version_list, civicrm_latest_release

    CiviCRM all releases page: https://download.civicrm.org/release/
    From the page.html file get a list of all the CiviCRM 6.0.0 and higher releases.
    We already know the
    CIVICRM_VERSION
    CIVICRM_RELEASE_LINK = "https://download.civicrm.org/release/"
    # CIVICRM_RELEASE_PAGE = "page.html"
    CIVICRM_RELEASE_PAGE = BACKUP_DIR + os.sep + "page.html"

    FYI: Dates of some releases:
    6.13.0 Released April 8, 2026;
    6.0.0 Released March 5, 2025
    5.0.0.Released April 4, 2018
    page.html will be in UPGRADE_DIR
    """
    os.chdir(HOME)

    # Download all the CiviCRM release as page.html file.
    # For subprocess - use list of commands and then set shell=False.
    print("\nDownloading CiviCRM releases information...")
    command_str = 'wget --quiet --output-document={} {}'.format(CIVICRM_RELEASE_PAGE, CIVICRM_RELEASE_LINK)
    command_list = command_str.split()
    #print(command_list)
    subprocess.check_output(command_list, shell=False)

    # Downloaded page.html /home/cmrailtr/civicrm-upgrade/page.html
    # Extract data from page.html in /home/cmrailtr/civicrm-upgrade/page.htm
    data_list = []
    with open(CIVICRM_RELEASE_PAGE, 'r') as fin:
        for index, line in enumerate(fin.readlines()):
            #   <a href="/release/6.13.0">6.13.0</a>
            position_start = line.find('"') + 1
            if position_start != -1:
                #print(index, position_start)
                position_end = line.find('"', position_start + 1)
                if position_end != -1:
                    #print(index, position_start, position_end)
                    data = line[position_start:position_end]
                    #print(data)
                    # /release/6.0.2 <--Extract the version number
                    position_start_1 = data.find("/release/") + 9
                    data_1 = data[position_start_1:]

                    if len(data_1) >0:
                        if data_1[0].isdigit(): # 1.5.7470
                            if int(data_1[0]) > 5:
                                data_list.append(data_1) #$"https://download.civicrm.org" + data)

    # Finished with page.html. Remove it.
    os.remove(CIVICRM_RELEASE_PAGE)

    data_list.sort(key=StrictVersion)  # StrictVersion sorts numeric as string
    #print(data_list)
    # ['6.0.0', '6.0.1', '6.0.2',... '6.13.2', '6.13.3', '6.14.0', '6.14.1']

    # Get the index of the current version in the data_list of all releases.
    position_current_version = data_list.index(CIVICRM_VERSION) if CIVICRM_VERSION in data_list else None
    if position_current_version == None:
        exit_program("Unable to find current CiviCRM version in list of Version Releases. Exiting")

    # If possible, show 5 releases after current release.
    # Otherwise truncate before or after.
    #lower_value = position_current_version - 5
    #if lower_value < 0:
    #    lower_value = 0
    upper_value = position_current_version + 6
    if upper_value > len(data_list):
        upper_value = len(data_list)

    civicrm_version_list = data_list[position_current_version:upper_value]
    #print(civicrm_version_list)

    # Also get the very latest release
    civicrm_latest_release = data_list[-1]

    return civicrm_version_list, civicrm_latest_release


def selector(prompt, select_list, default="0"):
    """
    Generate a menu style numeric value option selector.
    Expects: prompt, select_list - default first. OR Use default variable.
    Reverse list and index to have: 4, 3, 2, 1 and last one is 0 which is default.
    """
    while True:
        print("\t" + prompt)
        #for index, item in enumerate(select_list):
        for index, item in enumerate(reversed(select_list)):  # <-- reversed
            #print("\t\t" + str(index) + ". " + item)
            print("{}{:>2}. {}".format("\t", (len(select_list)-1) - index, item)) # <--index reversed

        return_str = raw_input("\n\t\tSelection [{}]: ".format(default))
        if return_str == "":
            return_str = default
        try:
            return_int = int(return_str)
            return_str = select_list[return_int]
            if return_int < 0 or return_int > len(select_list) -1:
                print("Invalid entry...")
                continue
            else:
                break
        except:
            print("Invalid entry...")
            continue

    #print(str(return_int), return_str)
    return return_int, return_str

